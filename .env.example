# Copy this file to .env.local and fill in real values. .env.local is
# gitignored by Create React App — do NOT commit the real key anywhere.
# Also set this same variable in Vercel → Project Settings → Environment
# Variables so production builds have it.

# Web3Forms access key — used by the contact form to send submissions.
# Get yours at https://web3forms.com and then:
#   1. Paste it into .env.local on your local machine
#   2. Add it to Vercel Environment Variables (Production + Preview)
#   3. On the Web3Forms dashboard, restrict allowed origins to:
#        https://guarddog-mgmt.vercel.app
#        (and your final custom domain when you have one)
#   4. Enable "Honeypot" spam protection if available
REACT_APP_WEB3FORMS_ACCESS_KEY=paste-your-access-key-here
